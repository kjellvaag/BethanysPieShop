@model HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<partial name="_Carousel" />

<div class="text-center">
    <img src="/images/bethanys-pie-shop-logomark.png" class="logo-mark" alt="Bethany's Pie Shop Logo">
    <h1>Pies of the week</h1>
    <hr class="header-line mx-auto">
    <h5>Enjoy a weekly selection of our favorite pies</h5>

    <div class="pies-of-the-week">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var pie in Model.PiesOfTheWeek)
            {
	            <partial name="_PieCard" model="pie" />
            }
        </div>
    </div>
</div>
